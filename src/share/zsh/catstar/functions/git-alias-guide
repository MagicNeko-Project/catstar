# DRY Core Printing Helper: Calculates padding and prints aligned columns
_git_alias_guide_print_table() {
  local database_item
  local -i maximum_alias_length=0 maximum_command_length=0
  local -a item_parts
  local current_alias current_command current_description padded_alias padded_command

  for database_item in "$@"; do
    item_parts=("${(@s:@@@:)database_item}")
    current_alias="${item_parts[1]}"
    current_command="${item_parts[2]}"
    if (( ${#current_alias} > maximum_alias_length )); then
      maximum_alias_length=${#current_alias}
    fi
    if (( ${#current_command} > maximum_command_length )); then
      maximum_command_length=${#current_command}
    fi
  done

  for database_item in "$@"; do
    item_parts=("${(@s:@@@:)database_item}")
    current_alias="${item_parts[1]}"
    current_command="${item_parts[2]}"
    current_description="${item_parts[4]}"

    padded_alias="${(r:maximum_alias_length + 2:: :)current_alias}"
    padded_command="${(r:maximum_command_length + 2:: :)current_command}"

    print -Pn "  %F{green}"
    print -rn -- "$padded_alias"
    print -Pn "%f  %F{yellow}"
    print -rn -- "$padded_command"
    print -Pn "%f  %F{white}"
    print -rn -- "$current_description"
    print -P "%f"
  done
}

# Helper 1: Print complete cheatsheet to pager
_git_alias_guide_print_cheatsheet() {
  local -a pager_command
  local chosen_category database_item item_parts
  local -a category_items

  if [[ -n $PAGER ]]; then
    pager_command=(${(z)PAGER})
  else
    pager_command=(less -RFX)
  fi
  if [[ ! -t 1 ]]; then
    pager_command=(cat)
  fi

  {
    print -P "%F{cyan}%B=========================================================================%f"
    print -P "%F{cyan}%B                 OH MY ZSH GIT ALIAS REFERENCE MANUAL                  %f"
    print -P "%F{cyan}%B=========================================================================%f"
    print -P "This manual documents the git aliases from Oh My Zsh. Use them to boost productivity!"
    print -P "To search, run: %F{green}git-alias-guide search <term>%f"
    print -P "To practice, run: %F{green}git-alias-guide quiz%f"
    print -P ""

    for chosen_category in "${categories[@]}"; do
      category_items=()
      for database_item in "${database[@]}"; do
        item_parts=("${(@s:@@@:)database_item}")
        if [[ "$item_parts[3]" == "$chosen_category" ]]; then
          category_items+=("$database_item")
        fi
      done

      if (( ${#category_items} == 0 )); then
        continue
      fi

      print -P "%F{blue}%B--- ${chosen_category} Aliases ---%f"
      _git_alias_guide_print_table "${category_items[@]}"
      print ""
    done
  } | "${pager_command[@]}"
}

# Helper 2: Search alias database
_git_alias_guide_search() {
  local search_query="$1"
  if [[ -z $search_query ]]; then
    print -u2 -P "%F{red}%BError:%b Please specify a search term.%f"
    return 1
  fi

  local search_query_lowercase="${(L)search_query}"
  local -a matching_items=()
  local database_item item_lowercase
  
  for database_item in "${database[@]}"; do
    item_lowercase="${(L)database_item}"
    if [[ "$item_lowercase" == *"$search_query_lowercase"* ]]; then
      matching_items+=("$database_item")
    fi
  done

  if (( ${#matching_items} == 0 )); then
    print -P "%F{yellow}No aliases found matching '%B${search_query}%b'.%f"
    return 0
  fi

  print -P "%F{blue}%B=== Search Results for '${search_query}' ===%f"
  print -P ""
  _git_alias_guide_print_table "${matching_items[@]}"
}

