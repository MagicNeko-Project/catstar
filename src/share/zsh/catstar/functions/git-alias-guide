  print -P "Test your knowledge and build muscle memory!"
  print -P "Answer 5 questions to complete a round. Press 'q' at any time to exit."
  print -P ""

  local -i total_questions=5
  local -i correct_answers_count=0
  local -i question_index
  local -i database_size=${#database}
  local -i correct_item_index question_type option_index random_option_index user_score_percentage distractor_index
  local correct_item correct_alias correct_command correct_description correct_option_text correct_label user_choice current_option distractor_item distractor_alias distractor_command
  local -a correct_parts option_texts shuffled_options distractor_parts
  local -a option_labels=("A" "B" "C" "D")

  for (( question_index = 1; question_index <= total_questions; question_index++ )); do
    print -P "%F{blue}%BQuestion ${question_index} of ${total_questions}:%f"
    
    correct_item_index=$(( RANDOM % database_size + 1 ))
    correct_item="${database[correct_item_index]}"
    
    correct_parts=("${(@s:@@@:)correct_item}")
    correct_alias="${correct_parts[1]}"
    correct_command="${correct_parts[2]}"
    correct_description="${correct_parts[4]}"

    question_type=$(( RANDOM % 2 ))
    option_texts=()
    
    if (( question_type == 0 )); then
      correct_option_text="$correct_alias"
      
      while (( ${#option_texts} < 3 )); do
        distractor_index=$(( RANDOM % database_size + 1 ))
        if (( distractor_index == correct_item_index )); then
          continue
        fi
        distractor_item="${database[distractor_index]}"
        distractor_parts=("${(@s:@@@:)distractor_item}")
        distractor_alias="${distractor_parts[1]}"
        
        if [[ "$distractor_alias" != "$correct_alias" && "${option_texts[(Ie)$distractor_alias]}" -eq 0 ]]; then
          option_texts+=("$distractor_alias")
        fi
      done
    else
      correct_option_text="$correct_command"
      
      while (( ${#option_texts} < 3 )); do
        distractor_index=$(( RANDOM % database_size + 1 ))
        if (( distractor_index == correct_item_index )); then
          continue
        fi
        distractor_item="${database[distractor_index]}"
        distractor_parts=("${(@s:@@@:)distractor_item}")
        distractor_command="${distractor_parts[2]}"
        
        if [[ "$distractor_command" != "$correct_command" && "${option_texts[(Ie)$distractor_command]}" -eq 0 ]]; then
          option_texts+=("$distractor_command")
        fi
      done
    fi

    option_texts+=("$correct_option_text")
    shuffled_options=()
    
    while (( ${#option_texts} > 0 )); do
      random_option_index=$(( RANDOM % ${#option_texts} + 1 ))
      shuffled_options+=("$option_texts[random_option_index]")
      option_texts[random_option_index]=()
    done

    # Print question safely
    if (( question_type == 0 )); then
      print -Pn "What is the short Zsh alias for: %F{yellow}%B"
      print -rn -- "$correct_command"
      print -P "%b%f?"
    else
      print -Pn "What Git command does the alias %F{green}%B"
      print -rn -- "$correct_alias"
      print -P "%b%f expand to?"
    fi
    print -P ""
    
    for (( option_index = 1; option_index <= 4; option_index++ )); do
      current_option="${shuffled_options[option_index]}"
      print -Pn "  %F{cyan}%B[${option_labels[option_index]}]%b%f "
      print -rn -- "$current_option"
      print ""
      if [[ "$current_option" == "$correct_option_text" ]]; then
        correct_label="${option_labels[option_index]}"
      fi
    done
    print -P ""

    while true; do
      print -P -n "%F{blue}Your answer (A/B/C/D or Q to quit): %f"
      read -r -s -k 1 user_choice
      user_choice="${(U)user_choice}"
      print "$user_choice"
      
      if [[ "$user_choice" == "Q" ]]; then
        print -P "%F{yellow}Quiz exited. Keep practicing!%f"
        return 0
      fi
      
      if [[ "$user_choice" == "A" || "$user_choice" == "B" || "$user_choice" == "C" || "$user_choice" == "D" ]]; then
        break
      fi
      
      print -P "%F{red}Invalid option. Please select A, B, C, or D.%f"
    done

    if [[ "$user_choice" == "$correct_label" ]]; then
      print -P "%F{green}%B✓ Correct!%b%f"
      correct_answers_count++
    else
      print -P "%F{red}%B✗ Incorrect.%b%f"
      if (( question_type == 0 )); then
        print -Pn "The correct alias is %F{green}%B"
        print -rn -- "$correct_alias"
        print -P "%b%f."
      else
        print -Pn "The correct command is %F{yellow}%B"
        print -rn -- "$correct_command"
        print -P "%b%f."
      fi
    fi
    
    print -Pn "%F{white}%BExplanation:%b "
    print -rn -- "$correct_description"
    print -P "%f"
    print -P ""
    
    if (( question_index < total_questions )); then
      print -n "Press any key to continue..."
      read -r -s -k 1
      print -P ""
    fi
  done

  print -P "%F{cyan}%B====================================================%f"
  print -P "%F{cyan}%B                QUIZ COMPLETED!                     %f"
  print -P "%F{cyan}%B====================================================%f"
  user_score_percentage=$(( (correct_answers_count * 100) / total_questions ))
  print -P "Your final score: %F{green}%B${correct_answers_count}/${total_questions}%b%f (${user_score_percentage}%)"
  if (( correct_answers_count == total_questions )); then
    print -P "%F{magenta}%BPerfect score! You are a Git Alias Master! 🌟%b%f"
  elif (( correct_answers_count >= 3 )); then
    print -P "%F{blue}%BGreat job! You are well on your way to git mastery.%b%f"
  else
    print -P "%F{yellow}%BKeep practicing to build muscle memory!%b%f"
  fi
  print -P ""
}

# Helper 4: Interactive Dashboard / Dashboard Menu
_git_alias_guide_menu() {
  local user_menu_choice category_choice chosen_category database_item current_alias current_command current_description padded_alias padded_command search_query
  local -i category_index maximum_alias_length maximum_command_length
  local -a category_items item_parts

  while true; do
    print -P ""
    print -P "%F{cyan}%B====================================================%f"
    print -P "%F{cyan}%B             GIT ALIAS INTERACTIVE GUIDE            %f"
    print -P "%F{cyan}%B====================================================%f"
    print -P "  %F{green}%B[1]%b%f Browse Aliases by Category"
    print -P "  %F{green}%B[2]%b%f Search for an Alias"
    print -P "  %F{green}%B[3]%b%f Start the Practice Quiz"
    print -P "  %F{green}%B[4]%b%f Exit Guide"
    print -P ""
    
    user_menu_choice=""
    print -P -n "%F{blue}Select an option (1-4): %f"
    read -r -s -k 1 user_menu_choice
    user_menu_choice="${(U)user_menu_choice}"
    print "$user_menu_choice"
    
    case "$user_menu_choice" in
      1)
        while true; do
          print -P ""
          print -P "%F{blue}%B--- Select a Category to Browse ---%f"
          for (( category_index = 1; category_index <= ${#categories}; category_index++ )); do
            print -P -n "  %F{green}%B[${category_index}]%b%f ${(r:12:: :)categories[category_index]}  "
            if (( category_index % 4 == 0 )); then
              print ""
            fi
          done
          print ""
          print -P "  %F{green}%B[B]%b%f Back to Main Menu"
          print ""
          
          # Standard read used for category selection because category options include double digits
          category_choice=""
          print -P -n "%F{blue}Select a category (1-${#categories} or B): %f"
          read -r category_choice
          
          if [[ "${(U)category_choice}" == "B" ]]; then
            break
          fi
          
          if [[ "$category_choice" =~ ^[0-9]+$ ]] && (( category_choice >= 1 && category_choice <= ${#categories} )); then
            chosen_category="${categories[category_choice]}"
            print -P ""
            print -P "%F{cyan}%B=== ${chosen_category} Aliases ===%f"
            print -P ""
            
            category_items=()
            for database_item in "${database[@]}"; do
              item_parts=("${(@s:@@@:)database_item}")
              if [[ "$item_parts[3]" == "$chosen_category" ]]; then
                category_items+=("$database_item")
              fi
            done
            
            _git_alias_guide_print_table "${category_items[@]}"
            
            print ""
            print -n "Press any key to return to category list..."
            read -r -s -k 1
            print ""
          else
            print -P "%F{red}Invalid option. Please select a valid category number or B.%f"
          fi
        done
        ;;
      2)
        search_query=""
        print -n "Enter search query: "
        read -r search_query
        _git_alias_guide_search "$search_query"
        print ""
        print -n "Press any key to return..."
        read -r -s -k 1
        print ""
        ;;
      3)
        _git_alias_guide_quiz
        print -n "Press any key to return..."
        read -r -s -k 1
        print ""
        ;;
      4)
        print -P "%F{yellow}Exiting guide. Happy coding!%f"
        return 0
        ;;
      *)
        print -P "%F{red}Invalid option. Please select 1-4.%f"
        ;;
    esac
  done
}

# Helper 5: Show usage/help page
_git_alias_guide_print_help() {
  print -P "%F{cyan}%BUsage: git-alias-guide [command | option]%f"
  print -P ""
  print -P "Commands:"
  print -P "  %F{green}search <term>%f      Search for aliases matching a query"
  print -P "  %F{green}quiz%f               Start the interactive training quiz"
  print -P "  %F{green}interactive%f        Start the dashboard menu interface"
  print -P "  %F{green}help%f               Show this help message"
  print -P ""
  print -P "Options:"
  print -P "  %F{green}-s, --search <term>%f Same as search command"
  print -P "  %F{green}-q, --quiz%f          Same as quiz command"
  print -P "  %F{green}-i, --interactive%f   Same as interactive command"
  print -P "  %F{green}-h, --help%f          Same as help command"
  print -P ""
  print -P "Without any arguments, shows the complete paginated cheatsheet like a man page."
  print -P "If an argument does not match a command, it will be treated as a search term."
}

# 3. Main Router Switch logic
if (( $# == 0 )); then
  _git_alias_guide_print_cheatsheet
  return 0
fi

case "$1" in
  search|-s|--search)
    shift
    _git_alias_guide_search "$*"
    ;;
  quiz|-q|--quiz)
    _git_alias_guide_quiz
    ;;
  interactive|-i|--interactive)
    _git_alias_guide_menu
    ;;
  help|--help|-h)
    _git_alias_guide_print_help
    ;;
  *)
    # Friendly fallback to search
    _git_alias_guide_search "$*"
    ;;
esac
