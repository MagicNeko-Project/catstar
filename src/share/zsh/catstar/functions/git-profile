# Manage Git author profiles
# Usage: git-profile [options] <command> [args...]

_git_profile_is_inside_git_repository() {
    command git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

_git_profile_show_help() {
    print -r -- 'Usage: git-profile [options] <command> [args...]

Manage Git author identities.

Identity Management:
  current                     Show active identity (default)
  list                        List profiles and active status
  use [<name>]                Apply a profile (interactively or by name)
  clear                       Remove the active identity

Profile Templates:
  add <name> [ref] [--use]    Create a new profile (and optionally apply it)
  set <name> <key> <value>    Update a profile key (name, email, signingkey)
  rename <old> <new>          Rename a profile
  delete <name>               Delete a profile

Backup & Synchronization:
  export [<name>...] [-o <f>] Export profiles to stdout or file
  import [file | -] [--force] Import profiles from file or stdin (default: stdin)

Options:
  --local                     Target repository config (default if in repo)
  --global                    Target global config
  -h, --help                  Show this help message'
}

# Profiles (templates) are ALWAYS stored in the global git config.
_git_profile_load_profiles() {
    local config_key config_value profile_path profile_name profile_property

    while read -r config_key config_value; do
        profile_path="${config_key#profile.}"
        profile_name="${profile_path%.*}"
        profile_property="${profile_path##*.}"

        if (( ! ${profile_list[(Ie)$profile_name]} )); then
            profile_list+=("$profile_name")
        fi

        case "$profile_property" in
            name) profile_names[$profile_name]="$config_value" ;;
            email) profile_emails[$profile_name]="$config_value" ;;
            signingkey) profile_keys[$profile_name]="$config_value" ;;
        esac
    done < <(command git config --global --get-regexp '^profile\.' 2>/dev/null)
}

_git_profile_find_matching_profile_name() {
    local target_name="$1"
    local target_email="$2"
    local target_key="$3"

    local -A profile_names profile_emails profile_keys
    local -a profile_list

    _git_profile_load_profiles

    local current_profile_name
    for current_profile_name in "${profile_list[@]}"; do
        local check_name="$profile_names[$current_profile_name]"
        local check_email="$profile_emails[$current_profile_name]"
        local check_key="$profile_keys[$current_profile_name]"

        if [[ "$check_name" == "$target_name" && "$check_email" == "$target_email" && ("$check_key" == "$target_key" || (-z "$check_key" && -z "$target_key")) ]]; then
            print -r -- "$current_profile_name"
            return 0
        fi
    done
    return 1
}

_git_profile_get_config_with_scope() {
    local key="$1"
    local scope_filter="$2"
    local output

    if [[ -n "$scope_filter" ]]; then
        output=$(command git config "$scope_filter" --show-scope "$key" 2>/dev/null)
    else
        output=$(command git config --show-scope "$key" 2>/dev/null)
    fi

    if [[ -n "$output" ]]; then
        print -r -- "$output"
    fi
}

_git_profile_get_active_identity() {
    local scope_filter="$1"
    local output

    output=$(_git_profile_get_config_with_scope "user.name" "$scope_filter")
    active_name="${output#*$'\t'}"
    active_name_scope="${output%%$'\t'*}"

    output=$(_git_profile_get_config_with_scope "user.email" "$scope_filter")
    active_email="${output#*$'\t'}"
    active_email_scope="${output%%$'\t'*}"

    output=$(_git_profile_get_config_with_scope "user.signingkey" "$scope_filter")
    active_key="${output#*$'\t'}"
    active_key_scope="${output%%$'\t'*}"
}

# Parse all options uniformly
local -A parsed_options
zparseopts -D -E -A parsed_options -local -global h -help -use -force o: -out:

if (( $+parsed_options[-h] )) || (( $+parsed_options[--help] )); then
    _git_profile_show_help
    return 0
fi

local selected_subcommand
if (( $# == 0 )); then
    selected_subcommand="current"
else
    selected_subcommand="$1"
    shift
fi

# Resolve target scope for the active identity operation
local target_scope=""
local explicit_scope_provided=0
if (( $+parsed_options[--local] )); then
    explicit_scope_provided=1
    if ! _git_profile_is_inside_git_repository; then
        print -u2 "Error: Operation requires a valid Git repository when targeting --local."
        return 1
    fi
    target_scope="--local"
elif (( $+parsed_options[--global] )); then
    explicit_scope_provided=1
    target_scope="--global"
else
    # Auto-detect scope default
    if _git_profile_is_inside_git_repository; then
        target_scope="--local"
    else
        # For read-only commands, safely default to global.
        # For write/mutation commands, fail to prevent implicit global state changes!
        case "$selected_subcommand" in
            current|list|add|set|rename|delete|export|import)
                if [[ "$selected_subcommand" == "add" ]] && (( $+parsed_options[--use] )); then
                    print -u2 "Error: Not inside a Git repository. To change your system-wide global identity, you must explicitly specify the --global flag."
                    return 1
                fi
                target_scope="--global"
                ;;
            use|clear)
                local action_verb="change"
                [[ "$selected_subcommand" == "clear" ]] && action_verb="clear"
                print -u2 "Error: Not inside a Git repository. To ${action_verb} your system-wide global identity, you must explicitly specify the --global flag."
                return 1
                ;;
        esac
    fi
fi

case "$selected_subcommand" in
    current|use|clear|list|add|set|rename|delete|export|import)
        # Valid subcommands
        ;;
    *)
        # Unknown subcommand
        _git_profile_show_help
        return 1
        ;;
esac

case "$selected_subcommand" in
    current)
        local active_name active_name_scope active_email active_email_scope active_key active_key_scope
        _git_profile_get_active_identity "$target_scope"

        if [[ -z "$active_name" && -z "$active_email" ]]; then
            print -r -- "No Git identity is currently configured in $target_scope scope."
            return 0
        fi

        local matched_profile_name
        matched_profile_name=$(_git_profile_find_matching_profile_name "$active_name" "$active_email" "$active_key")

        if [[ -n "$matched_profile_name" ]]; then
            print -r -- "Active profile: $matched_profile_name"
        else
            print -r -- "Active identity [No matching profile found]:"
        fi

        print -r -- "  Name:  $active_name (${active_name_scope:-unknown} scope)"
        print -r -- "  Email: $active_email (${active_email_scope:-unknown} scope)"
        if [[ -n "$active_key" ]]; then
            print -r -- "  Key:   $active_key (${active_key_scope:-unknown} scope)"
        fi
        return 0
        ;;

    list)
        local -A profile_names profile_emails profile_keys
        local -a profile_list
        _git_profile_load_profiles

        if [[ ${#profile_list} -eq 0 ]]; then
            print -r -- "No profiles exist in the global configuration."
            return 0
        fi

        local active_name active_name_scope active_email active_email_scope active_key active_key_scope
        _git_profile_get_active_identity "$target_scope"

        print -r -- "Available profiles:"
        printf "  %-1s %-20s %s\n" "" "PROFILE" "IDENTITY"
        printf "  %-1s %-20s %s\n" "" "-------" "--------"

        local current_profile_name
        for current_profile_name in "${(@n)profile_list}"; do
            local active_marker=" "
            local check_name="$profile_names[$current_profile_name]"
            local check_email="$profile_emails[$current_profile_name]"
            local check_key="$profile_keys[$current_profile_name]"

            if [[ "$check_name" == "$active_name" && "$check_email" == "$active_email" && ("$check_key" == "$active_key" || (-z "$check_key" && -z "$active_key")) ]]; then
                active_marker="*"
            fi
            printf "  %-1s %-20s %s <%s>%s\n" "$active_marker" "$current_profile_name" "$check_name" "$check_email" "${check_key:+ (Key: $check_key)}"
        done
        return 0
        ;;

    use)
        local target_profile_name="$1"

        if [[ -z "$target_profile_name" ]]; then
            if [[ ! -t 0 ]]; then
                print -u2 "Error: A profile name must be provided for non-interactive execution."
                return 1
            fi

            local -A profile_names profile_emails profile_keys
            local -a profile_list
            _git_profile_load_profiles

            if [[ ${#profile_list} -eq 0 ]]; then
                print -u2 "Error: No profiles exist to select from."
                return 1
            fi

            local active_name active_name_scope active_email active_email_scope active_key active_key_scope
            _git_profile_get_active_identity "$target_scope"

            print -r -- "Please select a profile to activate ($target_scope):"
            local current_profile_name active_marker
            local index=1
            local -a numerical_profile_map
            for current_profile_name in "${(@n)profile_list}"; do
                active_marker=" "
                local check_name="$profile_names[$current_profile_name]"
                local check_email="$profile_emails[$current_profile_name]"
                local check_key="$profile_keys[$current_profile_name]"

                if [[ "$check_name" == "$active_name" && "$check_email" == "$active_email" && ("$check_key" == "$active_key" || (-z "$check_key" && -z "$active_key")) ]]; then
                    active_marker="*"
                fi
                printf "%2d) %s %-20s : %s <%s>%s\n" "$index" "$active_marker" "$current_profile_name" "$check_name" "$check_email" "${check_key:+ (Key: $check_key)}"
                numerical_profile_map+=("$current_profile_name")
                ((index++))
            done

            print -r -- ""
            local user_selection
            while true; do
                print -n -- "Selection (1-${#numerical_profile_map}, or q to cancel): "
                read user_selection

                if [[ -z "$user_selection" || "$user_selection" == "q" || "$user_selection" == "quit" || "$user_selection" == "exit" ]]; then
                    print -r -- "Selection cancelled."
                    return 0
                fi

                if [[ "$user_selection" =~ ^[0-9]+$ ]] && (( user_selection >= 1 && user_selection <= ${#numerical_profile_map} )); then
                    target_profile_name="$numerical_profile_map[$user_selection]"
                    break
                else
                    print -u2 "Error: Selection must be a valid number between 1 and ${#numerical_profile_map}."
                fi
            done
        fi

        local stored_name stored_email stored_key
        stored_name=$(command git config --global --get "profile.$target_profile_name.name" 2>/dev/null)
        stored_email=$(command git config --global --get "profile.$target_profile_name.email" 2>/dev/null)
        stored_key=$(command git config --global --get "profile.$target_profile_name.signingkey" 2>/dev/null)

        if [[ -z "$stored_name" || -z "$stored_email" ]]; then
            print -u2 "Error: Profile '$target_profile_name' is missing required name or email."
            return 1
        fi

        command git config "$target_scope" user.name "$stored_name"
        command git config "$target_scope" user.email "$stored_email"
        if [[ -n "$stored_key" ]]; then
            command git config "$target_scope" user.signingkey "$stored_key"
        else
            command git config "$target_scope" --unset user.signingkey 2>/dev/null
        fi

        print -r -- "Git identity ($target_scope) set to: $stored_name <$stored_email>${stored_key:+ (Key: $stored_key)}"
        return 0
        ;;

    clear)
        local active_name active_name_scope active_email active_email_scope active_key active_key_scope
        _git_profile_get_active_identity "$target_scope"

        if [[ -z "$active_name" && -z "$active_email" ]]; then
            print -r -- "No identity is currently set in $target_scope."
            return 0
        fi

        local matched_profile_name
        matched_profile_name=$(_git_profile_find_matching_profile_name "$active_name" "$active_email" "$active_key")

        if [[ -n "$matched_profile_name" ]]; then
            command git config "$target_scope" --unset user.name
            command git config "$target_scope" --unset user.email
            command git config "$target_scope" --unset user.signingkey 2>/dev/null
            print -r -- "Successfully cleared identity for profile '$matched_profile_name' from $target_scope scope."
            return 0
        else
            print -u2 "Error: The active identity does not match any known profile. It will not be cleared automatically."
            return 1
        fi
        ;;

    add)
        local new_profile_name="$1"
        local commit_reference="$2"

        if [[ -z "$new_profile_name" ]]; then
            print -u2 "Error: A name must be provided for the new profile."
            return 1
        fi

        if command git config --global --get "profile.$new_profile_name.name" >/dev/null 2>&1; then
            print -u2 "Error: A profile named '$new_profile_name' already exists."
            return 1
        fi

        local input_name input_email input_key

        if [[ -n "$commit_reference" ]]; then
            if (( ! $+functions[git-commit-author] )); then
                print -u2 "Error: The 'git-commit-author' helper function is required to extract identity from a commit."
                return 1
            fi

            local extracted_author_info
            extracted_author_info=$(git-commit-author --get "$commit_reference" 2>/dev/null)
            if [[ $? -ne 0 || -z "$extracted_author_info" ]]; then
                print -u2 "Error: Failed to retrieve author information from reference '$commit_reference'."
                return 1
            fi

            input_name="${extracted_author_info%%$'\t'*}"
            input_email="${extracted_author_info#*$'\t'}"
            print -r -- "Successfully retrieved identity: $input_name <$input_email>"
        else
            print -n -- "Full Name: "
            read -r input_name
            print -n -- "Email:     "
            read -r input_email
            print -n -- "Signing Key (optional): "
            read -r input_key
        fi

        if [[ -z "$input_name" ]]; then
            print -u2 "Error: Full Name is required to create a profile."
            return 1
        fi

        if [[ -z "$input_email" ]]; then
            print -u2 "Error: Email is required to create a profile."
            return 1
        fi

        command git config --global "profile.$new_profile_name.name" "$input_name"
        command git config --global "profile.$new_profile_name.email" "$input_email"
        if [[ -n "$input_key" ]]; then
            command git config --global "profile.$new_profile_name.signingkey" "$input_key"
        fi

        print -r -- "Profile '$new_profile_name' was successfully created."

        if (( $+parsed_options[--use] )); then
            command git config "$target_scope" user.name "$input_name"
            command git config "$target_scope" user.email "$input_email"
            if [[ -n "$input_key" ]]; then
                command git config "$target_scope" user.signingkey "$input_key"
            else
                command git config "$target_scope" --unset user.signingkey 2>/dev/null
            fi
            print -r -- "Git identity ($target_scope) set to: $input_name <$input_email>${input_key:+ (Key: $input_key)}"
        fi
        return 0
        ;;

    set)
        local target_profile_name="$1"
        local update_key="$2"
        local update_value="$3"

        if [[ -z "$target_profile_name" || -z "$update_key" || -z "$update_value" ]]; then
             print -u2 "Usage Error: git-profile set <profile_name> <key> <value>"
             return 1
        fi

        if ! command git config --global --get "profile.$target_profile_name.name" >/dev/null 2>&1; then
            print -u2 "Error: Profile '$target_profile_name' does not exist."
            return 1
        fi

        case "$update_key" in
            name|email|signingkey)
                command git config --global "profile.$target_profile_name.$update_key" "$update_value"
                print -r -- "Successfully updated profile '$target_profile_name': '$update_key' set to '$update_value'."
                return 0
                ;;
            *)
                print -u2 "Error: Invalid property key '$update_key'. Allowed keys are: name, email, signingkey."
                return 1
                ;;
        esac
        ;;

    rename)
        local current_profile_name="$1"
        local new_profile_name="$2"

        if [[ -z "$current_profile_name" || -z "$new_profile_name" ]]; then
            print -u2 "Usage Error: git-profile rename <current_profile_name> <new_profile_name>"
            return 1
        fi

        local stored_name stored_email stored_key
        stored_name=$(command git config --global "profile.$current_profile_name.name" 2>/dev/null)
        stored_email=$(command git config --global "profile.$current_profile_name.email" 2>/dev/null)
        stored_key=$(command git config --global "profile.$current_profile_name.signingkey" 2>/dev/null)

        if [[ -z "$stored_name" ]]; then
            print -u2 "Error: Profile '$current_profile_name' does not exist."
            return 1
        fi

        if command git config --global --get "profile.$new_profile_name.name" >/dev/null 2>&1; then
            print -u2 "Error: A profile named '$new_profile_name' already exists."
            return 1
        fi

        command git config --global "profile.$new_profile_name.name" "$stored_name"
        command git config --global "profile.$new_profile_name.email" "$stored_email"
        if [[ -n "$stored_key" ]]; then
             command git config --global "profile.$new_profile_name.signingkey" "$stored_key"
        fi

        command git config --global --remove-section "profile.$current_profile_name" 2>/dev/null
        print -r -- "Successfully renamed profile from '$current_profile_name' to '$new_profile_name'."
        return 0
        ;;

    delete)
        local target_profile_name="$1"

        if [[ -z "$target_profile_name" ]]; then
            print -u2 "Error: Profile name is required to perform deletion."
            return 1
        fi

        if ! command git config --global --remove-section "profile.$target_profile_name" 2>/dev/null; then
            print -u2 "Error: Profile '$target_profile_name' does not exist."
            return 1
        fi
        print -r -- "Profile '$target_profile_name' was successfully deleted."
        return 0
        ;;

    export)
        local output_file_path="${parsed_options[-o]}${parsed_options[--out]}"
        local -a requested_profiles=("$@")
        local -a all_configuration_lines filtered_configuration_lines
        local current_profile_name current_line profile_found

        all_configuration_lines=("${(@f)$(command git config --global --get-regexp '^profile\.' 2>/dev/null)}")

        if [[ ${#all_configuration_lines} -eq 0 ]]; then
            if [[ ${#requested_profiles} -gt 0 ]]; then
                print -u2 "Error: No profiles exist in the global configuration to export."
                return 1
            fi
            return 0
        fi

        if [[ ${#requested_profiles} -gt 0 ]]; then
            for current_profile_name in "${requested_profiles[@]}"; do
                profile_found=0
                for current_line in "${all_configuration_lines[@]}"; do
                    if [[ "$current_line" == profile.$current_profile_name.* ]]; then
                        filtered_configuration_lines+=("$current_line")
                        profile_found=1
                    fi
                done

                if (( ! profile_found )); then
                    print -u2 "Error: Profile '$current_profile_name' was not found in the global configuration."
                    return 1
                fi
            done
        else
            filtered_configuration_lines=("${all_configuration_lines[@]}")
        fi

        if [[ -n "$output_file_path" ]]; then
            print -l -r -- "${filtered_configuration_lines[@]}" > "$output_file_path"
            print -r -- "Successfully exported profiles to '$output_file_path'."
        else
            print -l -r -- "${filtered_configuration_lines[@]}"
        fi
        return 0
        ;;

    import)
        local input_source_path="${1:--}"
        local -a file_lines parsed_import_data
        local current_line extracted_profile_name configuration_key configuration_value
        local -A new_profile_names

        if [[ "$input_source_path" == "-" ]]; then
            file_lines=("${(@f)$(</dev/stdin)}")
        else
            if [[ ! -f "$input_source_path" ]]; then
                print -u2 "Error: The specified import file '$input_source_path' does not exist."
                return 1
            fi
            file_lines=("${(@f)$(< "$input_source_path")}")
        fi

        if [[ ${#file_lines} -eq 0 ]]; then
            print -r -- "Import file is empty. Nothing to import."
            return 0
        fi

        for current_line in "${file_lines[@]}"; do
            [[ -z "${current_line//[[:space:]]/}" ]] && continue

            if [[ "$current_line" =~ ^profile\.([^.]+)\.([^ ]+)[[:space:]](.+)$ ]]; then
                extracted_profile_name="$match[1]"
                new_profile_names[$extracted_profile_name]=1
                parsed_import_data+=("$current_line")
            else
                print -u2 "Error: Encountered invalid import format at line: $current_line"
                return 1
            fi
        done

        # Pre-flight check for existing profiles if --force is not specified
        if (( ! ${+parsed_options[--force]} )); then
            for extracted_profile_name in "${(k)new_profile_names[@]}"; do
                if command git config --global --get-regexp "^profile\.$extracted_profile_name\." >/dev/null 2>&1; then
                    print -u2 "Error: Profile '$extracted_profile_name' already exists. Use --force flag to overwrite."
                    return 1
                fi
            done
        fi

        # Clean existing profiles if --force is specified
        if (( ${+parsed_options[--force]} )); then
            for extracted_profile_name in "${(k)new_profile_names[@]}"; do
                command git config --global --remove-section "profile.$extracted_profile_name" 2>/dev/null
            done
        fi

        # Apply imported data
        for current_line in "${parsed_import_data[@]}"; do
            configuration_key="${current_line%% *}"
            configuration_value="${current_line#* }"
            command git config --global "$configuration_key" "$configuration_value"
        done
        print -r -- "Successfully imported ${#new_profile_names} profile(s) into global scope."
        return 0
esac
