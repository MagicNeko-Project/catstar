# Update global gitignore using Catstar managed files
# Strictly avoids aggressive global config unless confirmed.

git-update-repo github/gitignore.git ~/.cfg/gitignore main

if [[ -z $GITIGNORE_INCLUDE ]]; then
    print "No GITIGNORE_INCLUDE defined. Skipping global gitignore update."
    return 0
fi

local gitignore_dest="$HOME/.gitignore"
local gitignore_content=""

local item
for item in $GITIGNORE_INCLUDE; do
    local file="$HOME/.cfg/gitignore/$item.gitignore"
    if [[ -f "$file" ]]; then
        gitignore_content+="# Source: $item\n$(<"$file")\n\n"
    fi
done

if [[ -n $gitignore_content ]]; then
    # Instead of forcesetting, we check if the user wants this.
    local current_excludes=$(git config --global core.excludesFile)
    if [[ $current_excludes != $gitignore_dest ]]; then
        print -P "%F{yellow}Warning:%f Global gitignore is not set to $gitignore_dest"
        print -n "Do you want to set git config --global core.excludesFile '$gitignore_dest'? (y/n) "
        read -q "answer"
        print
        if [[ $answer == [yY] ]]; then
            git config --global core.excludesFile "$gitignore_dest"
            print "Global excludesFile updated."
        fi
    fi
    print -rn "$gitignore_content" > $gitignore_dest
    print "Generated $gitignore_dest"
fi
