# Toggle a git remote (default: origin) between HTTP(S) and SSH.
# Usage: gtremote [remote-name]

local remote_name="${1:-origin}"

# --- 1. Guardrails & Help Menu ---
if [[ "$remote_name" == "-h" || "$remote_name" == "--help" ]]; then
    print "Usage: gtremote [remote-name]"
    print "Toggles a git remote (default: origin) between HTTP(S) and SSH."
    return 0
fi

# command git bypasses any user aliases to prevent infinite loops
if ! command git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    print -u2 "Error: Not inside a valid git repository."
    return 1
fi

local current_url
current_url=$(command git remote get-url "$remote_name" 2>/dev/null)

if [[ -z "$current_url" ]]; then
    print -u2 "Error: Remote '$remote_name' not found."
    return 1
fi

# --- 2. Pure Zsh URL Parsing ---
local host path new_url stripped

if [[ "$current_url" == http://* || "$current_url" == https://* ]]; then
    # Action: Convert HTTP(S) -> SSH
    stripped="${current_url#*://}" # Strip http:// or https://
    host="${stripped%%/*}"         # Extract everything before first '/'
    path="${stripped#*/}"          # Extract everything after first '/'

    # Strip any embedded credentials (e.g., user:pass@github.com)
    host="${host##*@}"

    new_url="git@${host}:${path}"
    print "Switched '$remote_name' to SSH: $new_url"

elif [[ "$current_url" == git@* ]]; then
    # Action: Convert Standard SSH -> HTTPS
    stripped="${current_url#git@}" # Strip git@
    host="${stripped%%:*}"         # Extract everything before first ':'
    path="${stripped#*:}"          # Extract everything after first ':'

    new_url="https://${host}/${path}"
    print "Switched '$remote_name' to HTTPS: $new_url"

elif [[ "$current_url" == ssh://* ]]; then
    # Action: Convert Alternate SSH -> HTTPS
    stripped="${current_url#ssh://}"
    stripped="${stripped#git@}"    # Strip optional git@ user
    host="${stripped%%/*}"         # Extract everything before first '/'
    path="${stripped#*/}"          # Extract everything after first '/'

    new_url="https://${host}/${path}"
    print "Switched '$remote_name' to HTTPS: $new_url"

else
    print -u2 "Error: Unsupported remote URL format: $current_url"
    return 1
fi

# --- 3. Normalization and Application ---
# Ensure the URL always ends in .git for consistency
[[ "$new_url" != *.git ]] && new_url="${new_url}.git"

command git remote set-url "$remote_name" "$new_url"
